pipeline {
    agent none
    stages {
        stage('Back-end') {
            agent { docker { image 'maven:3.8.1-adoptopenjdk-11' } }
            steps {
                sh 'mvn --version'
            }
        }

        stage('Front-end') {
            agent { docker { image 'node:16-alpine' } }
            steps {
                sh 'node --version'
            }
        }

        stage('Database Test') {
            agent { 
                docker { 
                    image 'mysql:8.0'
                    // Overriding entrypoint to let Jenkins control the shell
                    args "--entrypoint='' -e MYSQL_ROOT_PASSWORD=password" 
                } 
            }
            steps {
                echo "Starting MySQL Server in background..."
                sh '/usr/local/bin/docker-entrypoint.sh mysqld &'
                
                echo "Waiting for MySQL to be healthy..."
                // Instead of just sleeping, we try to ping the DB until it responds
                sh '''
                    attempt=0
                    until mysqladmin ping -h 127.0.0.1 -ppassword --silent || [ $attempt -gt 10 ]; do
                        echo "Waiting for database connection... (Attempt: $attempt)"
                        sleep 5
                        attempt=$((attempt + 1))
                    done
                '''
                
                sh 'mysql -u root -ppassword -h 127.0.0.1 -e "SHOW DATABASES;"'
                sh 'mysql -u root -ppassword -h 127.0.0.1 -e "CREATE DATABASE jenkins_test; SHOW DATABASES;"'
            }
        }
    }
}
